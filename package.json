{
  "name": "mcp-radar",
  "version": "1.0.0",
  "description": "Agent ecosystem intelligence using Bright Data MCP",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "web": "tsx src/server.ts",
